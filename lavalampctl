#!/bin/bash
#
# lavalampctl - Control the Lava Lamp app via its URL scheme
#
# Usage:
#   lavalampctl start                  Resume animation
#   lavalampctl stop                   Pause animation
#   lavalampctl toggle                 Toggle start/stop
#   lavalampctl set-color FF6600       Set color by hex
#   lavalampctl set-color 0.2 0.4 1.0  Set color by RGB floats (0.0-1.0)
#   lavalampctl random-color           Pick a random color
#   lavalampctl set-speed slow         Set speed (slow/normal/fast or float)
#   lavalampctl quit                   Quit the app
#   lavalampctl about                  Show app info
#   lavalampctl stats [--json|--yaml|--txt|--md]  Show lamp stats

set -euo pipefail

SCHEME="lavalamp"

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args...]

Commands:
  start                      Resume animation
  stop                       Pause animation
  toggle                     Toggle start/stop
  set-color <hex>            Set color by hex (e.g. FF6600 or #FF6600)
  set-color <r> <g> <b>      Set color by RGB floats (0.0-1.0)
  random-color               Pick a random harmonious color
  set-speed <value>          Set speed: slow, normal, fast, or a float
  quit                       Quit the app
  about                      Show app info
  stats [--json|--yaml|--txt|--md]
                             Show lamp stats (default: --txt)
EOF
    exit 1
}

if [ $# -lt 1 ]; then
    usage
fi

command="$1"
shift

case "$command" in
    start|stop|toggle|random-color|quit)
        open "${SCHEME}://${command}"
        ;;
    set-color)
        if [ $# -eq 1 ]; then
            open "${SCHEME}://set-color?hex=$1"
        elif [ $# -eq 3 ]; then
            open "${SCHEME}://set-color?r=$1&g=$2&b=$3"
        else
            echo "Error: set-color requires 1 hex value or 3 RGB floats"
            exit 1
        fi
        ;;
    set-speed)
        if [ $# -ne 1 ]; then
            echo "Error: set-speed requires a value (slow/normal/fast or float)"
            exit 1
        fi
        open "${SCHEME}://set-speed?value=$1"
        ;;
    stats)
        BUNDLE_ID="com.lavalamp.LavaLamp"
        FORMAT="${1:---txt}"

        # Check if app is running
        if pgrep -x "LavaLamp" > /dev/null 2>&1; then
            app_running="true"
            app_pid=$(pgrep -x "LavaLamp")
        else
            app_running="false"
            app_pid=""
        fi

        # Read settings from UserDefaults
        read_default() {
            defaults read "$BUNDLE_ID" "$1" 2>/dev/null || echo ""
        }

        color_r=$(read_default "lavaColorR")
        color_g=$(read_default "lavaColorG")
        color_b=$(read_default "lavaColorB")
        speed=$(read_default "speed")
        pixel_scale=$(read_default "pixelScale")
        window_x=$(read_default "windowPositionX")
        window_y=$(read_default "windowPositionY")

        # Defaults if not set
        color_r="${color_r:-1}"
        color_g="${color_g:-0.4}"
        color_b="${color_b:-0}"
        speed="${speed:-0.5}"
        pixel_scale="${pixel_scale:-2}"

        # Convert RGB floats to hex
        to_hex_component() {
            printf '%02X' "$(printf '%.0f' "$(echo "$1 * 255" | bc)")"
        }
        hex_r=$(to_hex_component "$color_r")
        hex_g=$(to_hex_component "$color_g")
        hex_b=$(to_hex_component "$color_b")
        color_hex="#${hex_r}${hex_g}${hex_b}"

        # Speed label
        case "$speed" in
            0.25) speed_label="slow" ;;
            0.5)  speed_label="normal" ;;
            1|1.0) speed_label="fast" ;;
            *)    speed_label="custom" ;;
        esac

        # Size label
        case "$pixel_scale" in
            1.5) size_label="small" ;;
            2|2.0) size_label="medium" ;;
            2.5) size_label="large" ;;
            *)   size_label="custom" ;;
        esac

        # Grid dimensions
        grid_width=48
        grid_height=120
        blob_count=5

        case "$FORMAT" in
            --json)
                cat <<EOJSON
{
  "app": {
    "name": "LavaLamp",
    "bundleId": "$BUNDLE_ID",
    "running": $app_running,
    "pid": ${app_pid:-null}
  },
  "color": {
    "hex": "$color_hex",
    "r": $color_r,
    "g": $color_g,
    "b": $color_b
  },
  "speed": {
    "value": $speed,
    "label": "$speed_label"
  },
  "size": {
    "pixelScale": $pixel_scale,
    "label": "$size_label"
  },
  "window": {
    "x": ${window_x:-null},
    "y": ${window_y:-null}
  },
  "grid": {
    "width": $grid_width,
    "height": $grid_height
  },
  "simulation": {
    "blobCount": $blob_count
  }
}
EOJSON
                ;;
            --yaml)
                cat <<EOYAML
app:
  name: LavaLamp
  bundleId: $BUNDLE_ID
  running: $app_running
  pid: ${app_pid:-~}
color:
  hex: "$color_hex"
  r: $color_r
  g: $color_g
  b: $color_b
speed:
  value: $speed
  label: $speed_label
size:
  pixelScale: $pixel_scale
  label: $size_label
window:
  x: ${window_x:-~}
  y: ${window_y:-~}
grid:
  width: $grid_width
  height: $grid_height
simulation:
  blobCount: $blob_count
EOYAML
                ;;
            --md)
                cat <<EOMD
# LavaLamp Stats

## App
| Property  | Value |
|-----------|-------|
| Name      | LavaLamp |
| Bundle ID | $BUNDLE_ID |
| Running   | $app_running |
| PID       | ${app_pid:--} |

## Color
| Property | Value |
|----------|-------|
| Hex      | $color_hex |
| R        | $color_r |
| G        | $color_g |
| B        | $color_b |

## Speed
| Property | Value |
|----------|-------|
| Value    | $speed |
| Label    | $speed_label |

## Size
| Property    | Value |
|-------------|-------|
| Pixel Scale | $pixel_scale |
| Label       | $size_label |

## Window
| Property | Value |
|----------|-------|
| X        | ${window_x:--} |
| Y        | ${window_y:--} |

## Grid
| Property | Value |
|----------|-------|
| Width    | $grid_width |
| Height   | $grid_height |

## Simulation
| Property   | Value |
|------------|-------|
| Blob Count | $blob_count |
EOMD
                ;;
            --txt|*)
                cat <<EOTXT
LavaLamp Stats
==============

App
  Name:         LavaLamp
  Bundle ID:    $BUNDLE_ID
  Running:      $app_running
  PID:          ${app_pid:--}

Color
  Hex:          $color_hex
  R:            $color_r
  G:            $color_g
  B:            $color_b

Speed
  Value:        $speed
  Label:        $speed_label

Size
  Pixel Scale:  $pixel_scale
  Label:        $size_label

Window
  X:            ${window_x:--}
  Y:            ${window_y:--}

Grid
  Width:        $grid_width
  Height:       $grid_height

Simulation
  Blob Count:   $blob_count
EOTXT
                ;;
        esac
        ;;
    about)
        cat <<'EOF'

         ██████
        ████████
       ██████████
      ████████████
      ██  ████████
      █ ██  ██████
      ████  ██████
      ██████  ████
      ████  ██  ██
      ██████  ████
      ████████████
      ████████████
      ████████████
      ████████████
       ██████████
        ████████
       ██████████
      ████████████
     ██████████████
     ██████████████
      ████████████

       LavaLamp App

  ─────────────────────────
  LARS GREGORI
  ─────────────────────────

  Work:       Technology Strategist
  LinkedIn:   linkedin.com/in/lars-gregori
  GitHub:     github.com/choas
  BlueSky:    bsky.app/profile/choas.net
  Mastodon:   mastodon.social/@choas
  Web:        larsgregori.de
  Apps:       apps.larsgregori.de

  Card:       npx choas-card

EOF
        ;;
    *)
        echo "Unknown command: $command"
        usage
        ;;
esac
