#!/bin/bash
#
# lavalampctl - Control the Lava Lamp app via its URL scheme
#
# Usage:
#   lavalampctl start                  Resume animation
#   lavalampctl stop                   Pause animation
#   lavalampctl toggle                 Toggle start/stop
#   lavalampctl set-color FF6600       Set color by hex
#   lavalampctl set-color 0.2 0.4 1.0  Set color by RGB floats (0.0-1.0)
#   lavalampctl random-color           Pick a random color
#   lavalampctl set-speed slow         Set speed (slow/normal/fast or float)
#   lavalampctl set-title "My Lamp"   Set title below the lamp
#   lavalampctl set-title-font Menlo  Set title font name
#   lavalampctl set-title-font-size 14 Set title font size
#   lavalampctl http --port <number>   Start HTTP server on port
#   lavalampctl http --stop            Stop HTTP server
#   lavalampctl web [--port <number>]  Open web UI (default port 8080)
#   lavalampctl quit                   Quit the app
#   lavalampctl about                  Show app info
#   lavalampctl stats [--json|--yaml|--txt|--md]  Show lamp stats
#   cat config.yaml | lavalampctl setup          Apply config from stdin

set -euo pipefail

SCHEME="lavalamp"

open_url() {
    osascript -e "open location \"$1\"" 2>/dev/null
}

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args...]

Commands:
  start                      Resume animation
  stop                       Pause animation
  toggle                     Toggle start/stop
  set-color <hex>            Set color by hex (e.g. FF6600 or #FF6600)
  set-color <r> <g> <b>      Set color by RGB floats (0.0-1.0)
  random-color               Pick a random harmonious color
  set-speed <value>          Set speed: slow, normal, fast, or a float
  set-title <text>           Set title below the lamp (empty to clear)
  set-title-font <name>      Set title font name (e.g. Menlo, Helvetica)
  set-title-font-size <size> Set title font size (e.g. 14)
  http --port <number>       Start HTTP server on port
  http --stop                Stop HTTP server
  web [--port <number>]      Open web control panel (default port 8080)
  quit                       Quit the app
  about                      Show app info
  stats [--json|--yaml|--txt|--md]
                             Show lamp stats (default: --txt)
  setup                      Apply config from stdin (YAML or JSON)
                             e.g. cat config.yaml | lavalampctl setup
EOF
    exit 1
}

if [ $# -lt 1 ]; then
    usage
fi

command="$1"
shift

case "$command" in
    start|stop|toggle|random-color|quit)
        open_url "${SCHEME}://${command}"
        ;;
    set-color)
        if [ $# -eq 1 ]; then
            open_url "${SCHEME}://set-color?hex=$1"
        elif [ $# -eq 3 ]; then
            open_url "${SCHEME}://set-color?r=$1&g=$2&b=$3"
        else
            echo "Error: set-color requires 1 hex value or 3 RGB floats"
            exit 1
        fi
        ;;
    set-speed)
        if [ $# -ne 1 ]; then
            echo "Error: set-speed requires a value (slow/normal/fast or float)"
            exit 1
        fi
        open_url "${SCHEME}://set-speed?value=$1"
        ;;
    set-title)
        if [ $# -lt 1 ]; then
            echo "Error: set-title requires a text value (use '' to clear)"
            exit 1
        fi
        encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$*'))")
        open_url "${SCHEME}://set-title?text=${encoded}"
        ;;
    set-title-font)
        if [ $# -ne 1 ]; then
            echo "Error: set-title-font requires a font name"
            exit 1
        fi
        encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$1'))")
        open_url "${SCHEME}://set-title-font?name=${encoded}"
        ;;
    set-title-font-size)
        if [ $# -ne 1 ]; then
            echo "Error: set-title-font-size requires a numeric size"
            exit 1
        fi
        open_url "${SCHEME}://set-title-font-size?value=$1"
        ;;
    web)
        port=8080
        if [ $# -eq 2 ] && [ "$1" = "--port" ]; then
            port="$2"
        elif [ $# -ne 0 ]; then
            echo "Error: usage: web [--port <number>]"
            exit 1
        fi
        open_url "${SCHEME}://web?port=${port}"
        echo "Opening web control panel on http://localhost:${port}/"
        ;;
    http)
        if [ $# -eq 2 ] && [ "$1" = "--port" ]; then
            open_url "${SCHEME}://http?port=$2"
            echo "HTTP server starting on port $2"
        elif [ $# -eq 1 ] && [ "$1" = "--stop" ]; then
            open_url "${SCHEME}://http?action=stop"
            echo "HTTP server stopping"
        else
            echo "Error: usage: http --port <number> | http --stop"
            exit 1
        fi
        ;;
    stats)
        BUNDLE_ID="com.lavalamp.LavaLamp"
        FORMAT="${1:---txt}"

        # Check if app is running
        if pgrep -x "LavaLamp" > /dev/null 2>&1; then
            app_running="true"
            app_pid=$(pgrep -x "LavaLamp")
        else
            app_running="false"
            app_pid=""
        fi

        # Read settings from UserDefaults
        read_default() {
            defaults read "$BUNDLE_ID" "$1" 2>/dev/null || echo ""
        }

        color_r=$(read_default "lavaColorR")
        color_g=$(read_default "lavaColorG")
        color_b=$(read_default "lavaColorB")
        speed=$(read_default "speed")
        pixel_scale=$(read_default "pixelScale")
        window_x=$(read_default "windowPositionX")
        window_y=$(read_default "windowPositionY")
        title=$(read_default "title")
        title_font=$(read_default "titleFont")
        title_font_size=$(read_default "titleFontSize")
        http_port=$(read_default "httpPort")

        # Defaults if not set
        title="${title:-}"
        title_font="${title_font:-Helvetica}"
        title_font_size="${title_font_size:-12}"
        color_r="${color_r:-1}"
        color_g="${color_g:-0.4}"
        color_b="${color_b:-0}"
        speed="${speed:-0.5}"
        pixel_scale="${pixel_scale:-2}"
        http_port="${http_port:-0}"

        # Convert RGB floats to hex
        to_hex_component() {
            printf '%02X' "$(printf '%.0f' "$(echo "$1 * 255" | bc)")"
        }
        hex_r=$(to_hex_component "$color_r")
        hex_g=$(to_hex_component "$color_g")
        hex_b=$(to_hex_component "$color_b")
        color_hex="#${hex_r}${hex_g}${hex_b}"

        # Speed label
        case "$speed" in
            0.25) speed_label="slow" ;;
            0.5)  speed_label="normal" ;;
            1|1.0) speed_label="fast" ;;
            *)    speed_label="custom" ;;
        esac

        # Size label
        case "$pixel_scale" in
            1.5) size_label="small" ;;
            2|2.0) size_label="medium" ;;
            2.5) size_label="large" ;;
            *)   size_label="custom" ;;
        esac

        # Grid dimensions
        grid_width=48
        grid_height=120
        blob_count=5

        case "$FORMAT" in
            --json)
                cat <<EOJSON
{
  "app": {
    "name": "LavaLamp",
    "bundleId": "$BUNDLE_ID",
    "running": $app_running,
    "pid": ${app_pid:-null}
  },
  "color": {
    "hex": "$color_hex",
    "r": $color_r,
    "g": $color_g,
    "b": $color_b
  },
  "speed": {
    "value": $speed,
    "label": "$speed_label"
  },
  "size": {
    "pixelScale": $pixel_scale,
    "label": "$size_label"
  },
  "window": {
    "x": ${window_x:-null},
    "y": ${window_y:-null}
  },
  "grid": {
    "width": $grid_width,
    "height": $grid_height
  },
  "simulation": {
    "blobCount": $blob_count
  },
  "title": {
    "text": "$title",
    "font": "$title_font",
    "fontSize": $title_font_size
  },
  "http": {
    "port": $http_port
  }
}
EOJSON
                ;;
            --yaml)
                cat <<EOYAML
app:
  name: LavaLamp
  bundleId: $BUNDLE_ID
  running: $app_running
  pid: ${app_pid:-~}
color:
  hex: "$color_hex"
  r: $color_r
  g: $color_g
  b: $color_b
speed:
  value: $speed
  label: $speed_label
size:
  pixelScale: $pixel_scale
  label: $size_label
window:
  x: ${window_x:-~}
  y: ${window_y:-~}
grid:
  width: $grid_width
  height: $grid_height
simulation:
  blobCount: $blob_count
title:
  text: "$title"
  font: $title_font
  fontSize: $title_font_size
http:
  port: $http_port
EOYAML
                ;;
            --md)
                cat <<EOMD
# LavaLamp Stats

## App
| Property  | Value |
|-----------|-------|
| Name      | LavaLamp |
| Bundle ID | $BUNDLE_ID |
| Running   | $app_running |
| PID       | ${app_pid:--} |

## Color
| Property | Value |
|----------|-------|
| Hex      | $color_hex |
| R        | $color_r |
| G        | $color_g |
| B        | $color_b |

## Speed
| Property | Value |
|----------|-------|
| Value    | $speed |
| Label    | $speed_label |

## Size
| Property    | Value |
|-------------|-------|
| Pixel Scale | $pixel_scale |
| Label       | $size_label |

## Window
| Property | Value |
|----------|-------|
| X        | ${window_x:--} |
| Y        | ${window_y:--} |

## Grid
| Property | Value |
|----------|-------|
| Width    | $grid_width |
| Height   | $grid_height |

## Simulation
| Property   | Value |
|------------|-------|
| Blob Count | $blob_count |

## Title
| Property  | Value |
|-----------|-------|
| Text      | ${title:--} |
| Font      | $title_font |
| Font Size | $title_font_size |

## HTTP
| Property | Value |
|----------|-------|
| Port     | $http_port |
EOMD
                ;;
            --txt|*)
                cat <<EOTXT
LavaLamp Stats
==============

App
  Name:         LavaLamp
  Bundle ID:    $BUNDLE_ID
  Running:      $app_running
  PID:          ${app_pid:--}

Color
  Hex:          $color_hex
  R:            $color_r
  G:            $color_g
  B:            $color_b

Speed
  Value:        $speed
  Label:        $speed_label

Size
  Pixel Scale:  $pixel_scale
  Label:        $size_label

Window
  X:            ${window_x:--}
  Y:            ${window_y:--}

Grid
  Width:        $grid_width
  Height:       $grid_height

Simulation
  Blob Count:   $blob_count

Title
  Text:         ${title:--}
  Font:         $title_font
  Font Size:    $title_font_size

HTTP
  Port:         $http_port
EOTXT
                ;;
        esac
        ;;
    setup)
        # Read YAML or JSON config from stdin and apply settings
        if [ -t 0 ]; then
            echo "Error: setup requires piped input"
            echo "Usage: cat config.yaml | $(basename "$0") setup"
            exit 1
        fi

        input=$(cat)

        urls=$(echo "$input" | python3 -c '
import sys, json
from urllib.parse import quote

def parse_simple_yaml(text):
    """Parse the simple two-level YAML produced by stats --yaml."""
    result = {}
    current_section = None
    for line in text.splitlines():
        stripped = line.rstrip()
        if not stripped or stripped.startswith("#"):
            continue
        if not line.startswith(" ") and stripped.endswith(":"):
            current_section = stripped[:-1]
            result[current_section] = {}
        elif line.startswith("  ") and current_section is not None and ":" in stripped:
            key, _, val = stripped.partition(":")
            key = key.strip()
            val = val.strip()
            # Remove surrounding quotes
            if len(val) >= 2 and val[0] == val[-1] and val[0] in ("\"", "'\''"):
                val = val[1:-1]
            # Convert types
            if val in ("~", "null", ""):
                val = None
            elif val == "true":
                val = True
            elif val == "false":
                val = False
            else:
                try:
                    val = int(val)
                except ValueError:
                    try:
                        val = float(val)
                    except ValueError:
                        pass
            result[current_section][key] = val
    return result

input_text = sys.stdin.read()
data = None

try:
    data = json.loads(input_text)
except (json.JSONDecodeError, ValueError):
    pass

if data is None:
    try:
        data = parse_simple_yaml(input_text)
    except Exception as e:
        print(f"Error: Could not parse input as JSON or YAML: {e}", file=sys.stderr)
        sys.exit(1)

if not isinstance(data, dict) or not data:
    print("Error: Input must be a non-empty JSON/YAML object", file=sys.stderr)
    sys.exit(1)

# Color
color = data.get("color", {})
if isinstance(color, dict):
    if "r" in color and "g" in color and "b" in color:
        cr, cg, cb = color["r"], color["g"], color["b"]
        print(f"lavalamp://set-color?r={cr}&g={cg}&b={cb}")
    elif "hex" in color:
        h = str(color["hex"]).lstrip("#")
        print(f"lavalamp://set-color?hex={h}")

# Speed
speed = data.get("speed", {})
if isinstance(speed, dict):
    if "value" in speed:
        sv = speed["value"]
        print(f"lavalamp://set-speed?value={sv}")
    elif "label" in speed:
        sl = speed["label"]
        print(f"lavalamp://set-speed?value={sl}")

# Title
title = data.get("title", {})
if isinstance(title, dict):
    if "text" in title and title["text"] is not None:
        tt = quote(str(title["text"]))
        print(f"lavalamp://set-title?text={tt}")
    if "font" in title and title["font"] is not None:
        tf = quote(str(title["font"]))
        print(f"lavalamp://set-title-font?name={tf}")
    if "fontSize" in title and title["fontSize"] is not None:
        ts = title["fontSize"]
        print(f"lavalamp://set-title-font-size?value={ts}")

# HTTP
http = data.get("http", {})
if isinstance(http, dict):
    if "port" in http and http["port"] is not None and int(http["port"]) > 0:
        hp = int(http["port"])
        print(f"lavalamp://http?port={hp}")
')

        if [ $? -ne 0 ]; then
            exit 1
        fi

        count=0
        echo "$urls" | while IFS= read -r url; do
            if [ -n "$url" ]; then
                open_url "$url"
                count=$((count + 1))
                echo "Applied: $url"
            fi
        done
        ;;
    about)
        SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
        VERSION=$(grep 'MARKETING_VERSION' "$SCRIPT_DIR/LavaLamp.xcodeproj/project.pbxproj" | head -1 | sed 's/.*= *\(.*\);/\1/' | tr -d ' ')
        cat <<EOF

           ███
         ███████
        /-------\\
       /   ██    \\
      /   ████    \\
     |   ██████    |
    |    ██████     |
    |     ████      |
    |      ██       |
    |               |
     |    ████     |
      \\  ██████   /
       \\  ████   /
        \\-------/
       ███████████
      █████████████
     ███████████████
    █████████████████

       LavaLamp App
         v${VERSION}

  https://github.com/choas/LavaLampApp

EOF
        ;;
    *)
        echo "Unknown command: $command"
        usage
        ;;
esac
